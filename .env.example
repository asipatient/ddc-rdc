ADMIN_EMAIL=admin@example.org
ADMIN_PASSWORD=change-this-local-password
# En production : utilisez ADMIN_PASSWORD_HASH (jamais ADMIN_PASSWORD en clair).
# Générez-le avec : npm run admin:hash "VotreMotDePasse"
# ADMIN_PASSWORD_HASH=scrypt:<salt>:<hash>
ADMIN_SESSION_SECRET=replace-with-a-long-random-secret
ADMIN_ROLE=super_admin

CONTACT_RECEIVER_EMAIL=ddc.democratie@gmail.com
NEXT_PUBLIC_PAYPAL_DONATION_URL=https://www.paypal.com/donate/?hosted_button_id=DN5YLHV58TCDE

# MySQL production storage, recommended for Congo Cloud/cPanel.
# Use either DATABASE_URL or the MYSQL_* variables below.
# Le nom de base recommandé est ddc_rdc_db (voir database/admin-schema.sql).
# DATABASE_URL=mysql://user:password@localhost:3306/ddc_rdc_db
# MYSQL_HOST=localhost
# MYSQL_PORT=3306
# MYSQL_DATABASE=ddc_rdc_db
# MYSQL_USER=database_user
# MYSQL_PASSWORD=database_password

# Optional email delivery through Resend.
# EMAIL_PROVIDER=resend
# EMAIL_API_KEY=
# EMAIL_FROM=DDC RDC <noreply@your-domain.org>

# Optional durable remote storage for form submissions.
# NEXT_PUBLIC_SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
